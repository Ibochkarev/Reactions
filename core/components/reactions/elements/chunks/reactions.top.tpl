<li class="reactions-top__item" data-idx="[[+idx]]" data-object-id="[[+object_id]]" data-class-key="[[+class_key]]">
    <a class="reactions-top__link" href="[[+uri:default=`#`]]">
        <span class="reactions-top__rank">#[[+idx]]</span>
        <span class="reactions-top__title">[[+pagetitle]]</span>
        <span class="reactions-top__meta">
            <span class="reactions-top__stat reactions-top__stat--primary" title="Likes">👍&nbsp;[[+likes]]</span>
            <span class="reactions-top__stat" title="Rating (likes − dislikes)">★&nbsp;[[+rating]]</span>
            <span class="reactions-top__stat" title="Total reactions">Σ&nbsp;[[+total]]</span>
            <span class="reactions-top__stat" title="Trending score">↗&nbsp;[[+trending_score]]</span>
        </span>
    </a>
</li>
